{
  "name": "genova",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "node-domexception": "^2.0.1"
    },
    "allowedDeprecatedVersions": {
      "node-domexception": "*"
    }
  },
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "lint": "pnpm --filter frontend lint",
    "format": "pnpm --filter frontend format",
    "dev:docker": "docker compose up --build",
    "prod:docker": "docker compose -f docker-compose.prod.yml up --build",
    "test:unit": "pnpm --filter genova-tests test:unit",
    "test:e2e": "pnpm --filter genova-tests test:e2e",
    "test:e2e:ui": "pnpm --filter genova-tests test:e2e:ui"
  }

}
