{"tipo":"Juego Drag & Drop","duracion":"2–3 min","interactividad":"Media","emoji":"🎮","resource_type":3,"concepto":"Árboles de decisión","raw_json":{"category_a":"Características","category_b":"Predicciones","rondas":[{"ronda":1,"item":"Edad","contexto":"Se utiliza para predecir la probabilidad de compra de un producto","respuesta":"A","feedback_correcto":"correcto, edad es una característica","feedback_incorrecto":"incorrecto, edad no es una predicción"},{"ronda":2,"item":"Precio","contexto":"Se utiliza para determinar el costo de un artículo","respuesta":"A","feedback_correcto":"correcto, precio es una característica","feedback_incorrecto":"incorrecto, precio no es una predicción"},{"ronda":3,"item":"Probabilidad de compra","contexto":"Se utiliza para determinar la posibilidad de que un cliente compre un producto","respuesta":"B","feedback_correcto":"correcto, probabilidad de compra es una predicción","feedback_incorrecto":"incorrecto, probabilidad de compra no es una característica"},{"ronda":4,"item":"Género","contexto":"Se utiliza para segmentar a los clientes en diferentes grupos","respuesta":"A","feedback_correcto":"correcto, género es una característica","feedback_incorrecto":"incorrecto, género no es una predicción"},{"ronda":5,"item":"Valor de predicción","contexto":"Se refiere al resultado de un modelo de predicción","respuesta":"B","feedback_correcto":"correcto, valor de predicción es una predicción","feedback_incorrecto":"incorrecto, valor de predicción no es una característica"},{"ronda":6,"item":"Histórico de compras","contexto":"Puede influir en la predicción de futuras compras, pero también es una característica del cliente","respuesta":"A","feedback_correcto":"correcto, histórco de compras es una característica","feedback_incorrecto":"incorrecto, histórco de compras también puede influir en la predicción"}]},"html_content":"<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Árboles de Decisión</title>\n  <style>\n    :root {\n      --bg: #f8fafc;\n      --surface: #ffffff;\n      --primary: #4f46e5;\n      --primary-hover: #6c5ce7;\n      --text: #0f172a;\n      --text-muted: #64748b;\n      --border: #dddddd;\n      --success: #34c759;\n      --danger: #ef4444;\n      --radius: 12px;\n      --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);\n      --space: 16px;\n    }\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n    body {\n      font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif;\n      background-color: var(--bg);\n      color: var(--text);\n      line-height: 1.5;\n    }\n    h1 {\n      font-weight: 700;\n      font-size: clamp(1.6rem, 4vw, 2.2rem);\n    }\n    h2 {\n      font-weight: 600;\n      font-size: clamp(1.3rem, 3vw, 1.6rem);\n    }\n    .container {\n      max-width: 880px;\n      padding: 20px;\n      margin: 0 auto;\n    }\n    .card {\n      background-color: var(--surface);\n      border-radius: var(--radius);\n      box-shadow: var(--shadow);\n      padding: var(--space);\n    }\n    .drag-item {\n      background-color: var(--surface);\n      border: 2px solid var(--border);\n      padding: var(--space);\n      margin-bottom: var(--space);\n      border-radius: var(--radius);\n      cursor: move;\n    }\n    .drag-item:hover {\n      border-color: var(--primary);\n    }\n    .drop-zone {\n      background-color: var(--surface);\n      border: 2px dashed var(--border);\n      padding: var(--space);\n      margin-bottom: var(--space);\n      border-radius: var(--radius);\n    }\n    .drop-zone:hover {\n      border-color: var(--primary);\n    }\n    .correct {\n      background-color: var(--success);\n      color: #ffffff;\n    }\n    .incorrect {\n      background-color: var(--danger);\n      color: #ffffff;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Árboles de Decisión</h1>\n    <p>Arrastre los items a las zonas correspondientes</p>\n    <div class=\"card\">\n      <h2>Características</h2>\n      <div class=\"drop-zone\" id=\"category-a\"></div>\n    </div>\n    <div class=\"card\">\n      <h2>Predicciones</h2>\n      <div class=\"drop-zone\" id=\"category-b\"></div>\n    </div>\n    <div class=\"card\">\n      <h2>Items</h2>\n      <div id=\"items\">\n        <!-- items generados dinámicamente -->\n      </div>\n    </div>\n  </div>\n  <script>\n    const datos = {\n      \"category_a\": \"Características\",\n      \"category_b\": \"Predicciones\",\n      \"rondas\": [\n        {\n          \"ronda\": 1,\n          \"item\": \"Edad\",\n          \"contexto\": \"Se utiliza para predecir la probabilidad de compra de un producto\",\n          \"respuesta\": \"A\",\n          \"feedback_correcto\": \"correcto, edad es una característica\",\n          \"feedback_incorrecto\": \"incorrecto, edad no es una predicción\"\n        },\n        {\n          \"ronda\": 2,\n          \"item\": \"Precio\",\n          \"contexto\": \"Se utiliza para determinar el costo de un artículo\",\n          \"respuesta\": \"A\",\n          \"feedback_correcto\": \"correcto, precio es una característica\",\n          \"feedback_incorrecto\": \"incorrecto, precio no es una predicción\"\n        },\n        {\n          \"ronda\": 3,\n          \"item\": \"Probabilidad de compra\",\n          \"contexto\": \"Se utiliza para determinar la posibilidad de que un cliente compre un producto\",\n          \"respuesta\": \"B\",\n          \"feedback_correcto\": \"correcto, probabilidad de compra es una predicción\",\n          \"feedback_incorrecto\": \"incorrecto, probabilidad de compra no es una característica\"\n        },\n        {\n          \"ronda\": 4,\n          \"item\": \"Género\",\n          \"contexto\": \"Se utiliza para segmentar a los clientes en diferentes grupos\",\n          \"respuesta\": \"A\",\n          \"feedback_correcto\": \"correcto, género es una característica\",\n          \"feedback_incorrecto\": \"incorrecto, género no es una predicción\"\n        },\n        {\n          \"ronda\": 5,\n          \"item\": \"Valor de predicción\",\n          \"contexto\": \"Se refiere al resultado de un modelo de predicción\",\n          \"respuesta\": \"B\",\n          \"feedback_correcto\": \"correcto, valor de predicción es una predicción\",\n          \"feedback_incorrecto\": \"incorrecto, valor de predicción no es una característica\"\n        },\n        {\n          \"ronda\": 6,\n          \"item\": \"Histórico de compras\",\n          \"contexto\": \"Puede influir en la predicción de futuras compras, pero también es una característica del cliente\",\n          \"respuesta\": \"A\",\n          \"feedback_correcto\": \"correcto, histórco de compras es una característica\",\n          \"feedback_incorrecto\": \"incorrecto, histórco de compras también puede influir en la predicción\"\n        }\n      ]\n    };\n\n    const itemContainer = document.getElementById(\"items\");\n    const categoryA = document.getElementById(\"category-a\");\n    const categoryB = document.getElementById(\"category-b\");\n\n    let puntuacion = 0;\n\n    datos.rondas.forEach((ronda) => {\n      const item = document.createElement(\"div\");\n      item.classList.add(\"drag-item\");\n      item.draggable = true;\n      item.id = `item-${ronda.ronda}`;\n      item.innerHTML = `${ronda.item} - ${ronda.contexto}`;\n      item.addEventListener(\"dragstart\", (e) => {\n        e.dataTransfer.setData(\"text\", ronda.ronda);\n      });\n      itemContainer.appendChild(item);\n    });\n\n    categoryA.addEventListener(\"dragover\", (e) => {\n      e.preventDefault();\n    });\n\n    categoryA.addEventListener(\"drop\", (e) => {\n      e.preventDefault();\n      const itemRonda = parseInt(e.dataTransfer.getData(\"text\"));\n      const item = datos.rondas.find((ronda) => ronda.ronda === itemRonda);\n      if (item.respuesta === \"A\") {\n        puntuacion++;\n        itemContainer.removeChild(document.getElementById(`item-${itemRonda}`));\n        categoryA.innerHTML += `<p class=\"correct\">${item.item} - ${item.feedback_correcto}</p>`;\n      } else {\n        categoryA.innerHTML += `<p class=\"incorrect\">${item.item} - ${item.feedback_incorrecto}</p>`;\n      }\n    });\n\n    categoryB.addEventListener(\"dragover\", (e) => {\n      e.preventDefault();\n    });\n\n    categoryB.addEventListener(\"drop\", (e) => {\n      e.preventDefault();\n      const itemRonda = parseInt(e.dataTransfer.getData(\"text\"));\n      const item = datos.rondas.find((ronda) => ronda.ronda === itemRonda);\n      if (item.respuesta === \"B\") {\n        puntuacion++;\n        itemContainer.removeChild(document.getElementById(`item-${itemRonda}`));\n        categoryB.innerHTML += `<p class=\"correct\">${item.item} - ${item.feedback_correcto}</p>`;\n      } else {\n        categoryB.innerHTML += `<p class=\"incorrect\">${item.item} - ${item.feedback_incorrecto}</p>`;\n      }\n    });\n\n    function _scormInit() {\n      if (window.API) window.API.LMSInitialize(\"\");\n    }\n\n    function _scormComplete(s) {\n      if (window.API) {\n        if (s != null) window.API.LMSSetValue(\"cmi.core.score.raw\", s);\n        window.API.LMSSetValue(\"cmi.core.lesson_status\", \"completed\");\n        window.API.LMSCommit(\"\");\n        window.API.LMSFinish(\"\");\n      }\n    }\n\n    window.addEventListener(\"load\", _scormInit);\n\n    window.addEventListener(\"beforeunload\", () => {\n      _scormComplete(puntuacion);\n    });\n  </script>\n</body>\n</html>"}