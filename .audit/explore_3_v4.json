{"tipo":"Juego Drag & Drop","duracion":"2–3 min","interactividad":"Media","emoji":"🎮","resource_type":3,"concepto":"Árboles de decisión","raw_json":{"category_a":"Pronóstico de alta probabilidad de lluvia","category_b":"Pronóstico de baja probabilidad de lluvia","rondas":[{"ronda":1,"item":"Nubes oscuras y viento fuerte","contexto":"Un sistema de baja presión se acerca","respuesta":"A","feedback_correcto":"Correcto, lluvia probable","feedback_incorrecto":"Incorrecto, nubes oscuras indican lluvia"},{"ronda":2,"item":"Cielo despejado y sol","contexto":"Un sistema de alta presión domina la región","respuesta":"B","feedback_correcto":"Correcto, no se espera lluvia","feedback_incorrecto":"Incorrecto, cielo despejado indica buen tiempo"},{"ronda":3,"item":"Nubes blancas y dispersas","contexto":"Un sistema de alta presión se mantiene estable","respuesta":"B","feedback_correcto":"Correcto, no se espera lluvia","feedback_incorrecto":"Incorrecto, nubes blancas no siempre indican lluvia"},{"ronda":4,"item":"Temperatura cayendo rápidamente","contexto":"Un frente frío se acerca","respuesta":"A","feedback_correcto":"Correcto, lluvia posible","feedback_incorrecto":"Incorrecto, temperatura cayendo no siempre indica lluvia"},{"ronda":5,"item":"Humedad relativa del 80%","contexto":"Un sistema de baja presión se forma en el oeste","respuesta":"A","feedback_correcto":"Correcto, humedad alta indica lluvia","feedback_incorrecto":"Incorrecto, humedad alta no siempre indica lluvia"},{"ronda":6,"item":"Viento moderado y nubes altas","contexto":"Un sistema de alta presión se debilita","respuesta":"A","feedback_correcto":"Correcto, lluvia posible","feedback_incorrecto":"Incorrecto, viento moderado no siempre indica lluvia"}]},"html_content":"<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Árboles de Decisión: Pronóstico de Lluvia</title>\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n        \n        :root {\n            --bg: #f8fafc;\n            --surface: #ffffff;\n            --primary: #4f46e5;\n            --primary-hover: #4338ca;\n            --text: #0f172a;\n            --text-muted: #64748b;\n            --border: #e2e8f0;\n            --success: #10b981;\n            --danger: #ef4444;\n            --radius: 12px;\n            --shadow: 0 4px 12px rgba(0,0,0,0.08);\n            --space-8: 8px;\n            --space-12: 12px;\n            --space-16: 16px;\n            --space-24: 24px;\n            --space-32: 32px;\n            --space-48: 48px;\n        }\n        \n        body {\n            font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif;\n            background-color: var(--bg);\n            color: var(--text);\n            line-height: 1.5;\n            font-size: clamp(0.95rem, 2vw, 1.05rem);\n        }\n        \n        .container {\n            max-width: 880px;\n            margin: 0 auto;\n            padding: var(--space-32) var(--space-20);\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: var(--space-48);\n            animation: fadeIn 0.5s ease-out;\n        }\n        \n        h1 {\n            font-size: clamp(1.6rem, 4vw, 2.2rem);\n            font-weight: 700;\n            line-height: 1.2;\n            margin-bottom: var(--space-8);\n        }\n        \n        .subtitle {\n            color: var(--text-muted);\n            font-size: clamp(1rem, 2.5vw, 1.2rem);\n            font-weight: 500;\n        }\n        \n        .score-board {\n            background: var(--surface);\n            border-radius: var(--radius);\n            box-shadow: var(--shadow);\n            padding: var(--space-24);\n            margin-bottom: var(--space-32);\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            animation: slideIn 0.5s ease-out;\n        }\n        \n        .score {\n            font-size: 1.2rem;\n            font-weight: 600;\n        }\n        \n        .score span {\n            color: var(--primary);\n            font-weight: 700;\n            font-size: 1.4rem;\n        }\n        \n        .reset-btn {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: var(--space-12) var(--space-24);\n            border-radius: var(--radius);\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 200ms ease;\n        }\n        \n        .reset-btn:hover {\n            background: var(--primary-hover);\n            transform: translateY(-1px);\n            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.2);\n        }\n        \n        .reset-btn:focus-visible {\n            outline: 3px solid var(--primary);\n            outline-offset: 2px;\n        }\n        \n        .game-area {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: var(--space-32);\n        }\n        \n        .current-item {\n            background: var(--surface);\n            border-radius: var(--radius);\n            box-shadow: var(--shadow);\n            padding: var(--space-24);\n            transform: translateY(0);\n            transition: all 300ms ease;\n            animation: itemAppear 0.5s ease-out;\n        }\n        \n        .current-item.dragging {\n            opacity: 0.5;\n            transform: scale(0.95);\n        }\n        \n        .round-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: var(--space-16);\n        }\n        \n        .round-number {\n            background: var(--primary);\n            color: white;\n            padding: var(--space-8) var(--space-16);\n            border-radius: 20px;\n            font-weight: 600;\n        }\n        \n        .item-content {\n            background: var(--bg);\n            border: 2px solid var(--border);\n            border-radius: var(--radius);\n            padding: var(--space-20);\n            margin-top: var(--space-16);\n            cursor: move;\n            transition: all 200ms ease;\n        }\n        \n        .item-content:hover {\n            border-color: var(--primary);\n            transform: translateY(-2px);\n            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.1);\n        }\n        \n        .item-content:focus {\n            outline: 3px solid var(--primary);\n            outline-offset: 2px;\n        }\n        \n        .item-text {\n            font-weight: 600;\n            margin-bottom: var(--space-8);\n        }\n        \n        .contexto {\n            color: var(--text-muted);\n            font-size: 0.9rem;\n        }\n        \n        .drop-zones {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: var(--space-24);\n        }\n        \n        .drop-zone {\n            background: var(--surface);\n            border: 3px dashed var(--border);\n            border-radius: var(--radius);\n            padding: var(--space-24);\n            text-align: center;\n            min-height: 150px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            transition: all 300ms ease;\n            position: relative;\n        }\n        \n        .drop-zone.drag-over {\n            background: rgba(79, 70, 229, 0.05);\n            border-color: var(--primary);\n            transform: scale(1.02);\n        }\n        \n        .drop-zone-label {\n            font-weight: 600;\n            margin-bottom: var(--space-12);\n            color: var(--text);\n        }\n        \n        .drop-zone-content {\n            color: var(--text-muted);\n            font-size: 0.9rem;\n        }\n        \n        .feedback {\n            margin-top: var(--space-24);\n            padding: var(--space-20);\n            border-radius: var(--radius);\n            font-weight: 500;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(10px);\n            transition: all 300ms ease;\n        }\n        \n        .feedback.show {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .feedback.correct {\n            background: rgba(16, 185, 129, 0.1);\n            color: var(--success);\n            border: 1px solid var(--success);\n        }\n        \n        .feedback.incorrect {\n            background: rgba(239, 68, 68, 0.1);\n            color: var(--danger);\n            border: 1px solid var(--danger);\n        }\n        \n        .next-btn {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: var(--space-16) var(--space-32);\n            border-radius: var(--radius);\n            font-weight: 600;\n            cursor: pointer;\n            margin: var(--space-24) auto 0;\n            display: none;\n            transition: all 200ms ease;\n        }\n        \n        .next-btn.show {\n            display: block;\n        }\n        \n        .next-btn:hover {\n            background: var(--primary-hover);\n            transform: translateY(-1px);\n            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.2);\n        }\n        \n        .completion-message {\n            background: var(--surface);\n            border-radius: var(--radius);\n            box-shadow: var(--shadow);\n            padding: var(--space-32);\n            text-align: center;\n            display: none;\n        }\n        \n        .completion-message.show {\n            display: block;\n            animation: fadeIn 0.5s ease-out;\n        }\n        \n        .completion-icon {\n            font-size: 3rem;\n            margin-bottom: var(--space-16);\n        }\n        \n        .completion-text {\n            font-size: 1.5rem;\n            font-weight: 600;\n            margin-bottom: var(--space-16);\n        }\n        \n        .final-score {\n            font-size: 1.2rem;\n            color: var(--text-muted);\n            margin-bottom: var(--space-24);\n        }\n        \n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n            }\n            to {\n                opacity: 1;\n            }\n        }\n        \n        @keyframes slideIn {\n            from {\n                transform: translateY(20px);\n                opacity: 0;\n            }\n            to {\n                transform: translateY(0);\n                opacity: 1;\n            }\n        }\n        \n        @keyframes itemAppear {\n            from {\n                transform: translateY(20px);\n                opacity: 0;\n            }\n            to {\n                transform: translateY(0);\n                opacity: 1;\n            }\n        }\n        \n        @media (prefers-reduced-motion: reduce) {\n            * {\n                animation: none !important;\n                transition: none !important;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Árboles de Decisión: Pronóstico de Lluvia</h1>\n            <p class=\"subtitle\">Clasifica cada condición meteorológica según su probabilidad de lluvia</p>\n        </header>\n        \n        <div class=\"score-board\">\n            <div class=\"score\">Puntuación: <span id=\"score\">0</span>/6</div>\n            <button class=\"reset-btn\" role=\"button\" onclick=\"resetGame()\">Reiniciar Juego</button>\n        </div>\n        \n        <main class=\"game-area\">\n            <div id=\"game-container\">\n                <div class=\"current-item\">\n                    <div class=\"round-header\">\n                        <h2>Ronda <span id=\"round-number\">1</span></h2>\n                    </div>\n                    <div class=\"item-content\" \n                         id=\"draggable-item\" \n                         draggable=\"true\" \n                         role=\"button\" \n                         tabindex=\"0\"\n                         aria-label=\"Arrastrar esta condición meteorológica\">\n                        <p class=\"item-text\" id=\"item-text\">Nubes oscuras y viento fuerte</p>\n                        <p class=\"contexto\" id=\"item-contexto\">Un sistema de baja presión se acerca</p>\n                    </div>\n                </div>\n                \n                <div class=\"drop-zones\">\n                    <div class=\"drop-zone\" \n                         id=\"drop-zone-a\" \n                         data-category=\"A\"\n                         aria-label=\"Soltar aquí para clasificar como alta probabilidad de lluvia\">\n                        <div class=\"drop-zone-label\">Pronóstico de alta probabilidad de lluvia</div>\n                        <div class=\"drop-zone-content\">Arrastra aquí las condiciones que indican lluvia</div>\n                    </div>\n                    <div class=\"drop-zone\" \n                         id=\"drop-zone-b\" \n                         data-category=\"B\"\n                         aria-label=\"Soltar aquí para clasificar como baja probabilidad de lluvia\">\n                        <div class=\"drop-zone-label\">Pronóstico de baja probabilidad de lluvia</div>\n                        <div class=\"drop-zone-content\">Arrastra aquí las condiciones que indican buen tiempo</div>\n                    </div>\n                </div>\n                \n                <div class=\"feedback\" id=\"feedback\"></div>\n                <button class=\"next-btn\" id=\"next-btn\" role=\"button\" onclick=\"nextRound()\">Siguiente Ronda</button>\n            </div>\n            \n            <div class=\"completion-message\" id=\"completion-message\">\n                <div class=\"completion-icon\">🌧️</div>\n                <div class=\"completion-text\">¡Juego Completado!</div>\n                <p class=\"final-score\">Puntuación Final: <span id=\"final-score\">0</span>/6</p>\n                <button class=\"reset-btn\" role=\"button\" onclick=\"resetGame()\">Jugar de Nuevo</button>\n            </div>\n        </main>\n    </div>\n    \n    <script>\n        const data = {\n            \"category_a\": \"Pronóstico de alta probabilidad de lluvia\",\n            \"category_b\": \"Pronóstico de baja probabilidad de lluvia\",\n            \"rondas\": [\n                {\n                    \"ronda\": 1,\n                    \"item\": \"Nubes oscuras y viento fuerte\",\n                    \"contexto\": \"Un sistema de baja presión se acerca\",\n                    \"respuesta\": \"A\",\n                    \"feedback_correcto\": \"Correcto, lluvia probable\",\n                    \"feedback_incorrecto\": \"Incorrecto, nubes oscuras indican lluvia\"\n                },\n                {\n                    \"ronda\": 2,\n                    \"item\": \"Cielo despejado y sol\",\n                    \"contexto\": \"Un sistema de alta presión domina la región\",\n                    \"respuesta\": \"B\",\n                    \"feedback_correcto\": \"Correcto, no se espera lluvia\",\n                    \"feedback_incorrecto\": \"Incorrecto, cielo despejado indica buen tiempo\"\n                },\n                {\n                    \"ronda\": 3,\n                    \"item\": \"Nubes blancas y dispersas\",\n                    \"contexto\": \"Un sistema de alta presión se mantiene estable\",\n                    \"respuesta\": \"B\",\n                    \"feedback_correcto\": \"Correcto, no se espera lluvia\",\n                    \"feedback_incorrecto\": \"Incorrecto, nubes blancas no siempre indican lluvia\"\n                },\n                {\n                    \"ronda\": 4,\n                    \"item\": \"Temperatura cayendo rápidamente\",\n                    \"contexto\": \"Un frente frío se acerca\",\n                    \"respuesta\": \"A\",\n                    \"feedback_correcto\": \"Correcto, lluvia posible\",\n                    \"feedback_incorrecto\": \"Incorrecto, temperatura cayendo no siempre indica lluvia\"\n                },\n                {\n                    \"ronda\": 5,\n                    \"item\": \"Humedad relativa del 80%\",\n                    \"contexto\": \"Un sistema de baja presión se forma en el oeste\",\n                    \"respuesta\": \"A\",\n                    \"feedback_correcto\": \"Correcto, humedad alta indica lluvia\",\n                    \"feedback_incorrecto\": \"Incorrecto, humedad alta no siempre indica lluvia\"\n                },\n                {\n                    \"ronda\": 6,\n                    \"item\": \"Viento moderado y nubes altas\",\n                    \"contexto\": \"Un sistema de alta presión se debilita\",\n                    \"respuesta\": \"A\",\n                    \"feedback_correcto\": \"Correcto, lluvia posible\",\n                    \"feedback_incorrecto\": \"Incorrecto, viento moderado no siempre indica lluvia\"\n                }\n            ]\n        };\n        \n        let currentRound = 0;\n        let score = 0;\n        let isDragging = false;\n        \n        const draggableItem = document.getElementById('draggable-item');\n        const dropZoneA = document.getElementById('drop-zone-a');\n        const dropZoneB = document.getElementById('drop-zone-b');\n        const feedback = document.getElementById('feedback');\n        const nextBtn = document.getElementById('next-btn');\n        const gameContainer = document.getElementById('game-container');\n        const completionMessage = document.getElementById('completion-message');\n        const scoreDisplay = document.getElementById('score');\n        \n        // Drag and drop handlers\n        draggableItem.addEventListener('dragstart', handleDragStart);\n        draggableItem.addEventListener('dragend', handleDragEnd);\n        dropZoneA.addEventListener('dragover', handleDragOver);\n        dropZoneB.addEventListener('dragover', handleDragOver);\n        dropZoneA.addEventListener('drop', handleDrop);\n        dropZoneB.addEventListener('drop', handleDrop);\n        \n        // Touch support\n        draggableItem.addEventListener('touchstart', handleTouchStart, {passive: false});\n        draggableItem.addEventListener('touchmove', handleTouchMove, {passive: false});\n        draggableItem.addEventListener('touchend', handleTouchEnd);\n        \n        function handleDragStart(e) {\n            isDragging = true;\n            draggableItem.classList.add('dragging');\n            e.dataTransfer.effectAllowed = 'move';\n            e.dataTransfer.setData('text/plain', 'meteorological-item');\n        }\n        \n        function handleDragEnd(e) {\n            isDragging = false;\n            draggableItem.classList.remove('dragging');\n        }\n        \n        function handleDragOver(e) {\n            e.preventDefault();\n            e.currentTarget.classList.add('drag-over');\n        }\n        \n        function handleDrop(e) {\n            e.preventDefault();\n            e.currentTarget.classList.remove('drag-over');\n            \n            if (isDragging) {\n                const category = e.currentTarget.dataset.category;\n                processDrop(category);\n            }\n        }\n        \n        // Touch handlers\n        let touchItem = null;\n        let touchOffset = {x: 0, y: 0};\n        \n        function handleTouchStart(e) {\n            touchItem = e.target.closest('.item-content');\n            const touch = e.touches[0];\n            const rect = touchItem.getBoundingClientRect();\n            touchOffset.x = touch.clientX - rect.left;\n            touchOffset.y = touch.clientY - rect.top;\n            touchItem.style.position = 'fixed';\n            touchItem.style.zIndex = '1000';\n            touchItem.style.transition = 'none';\n            e.preventDefault();\n        }\n        \n        function handleTouchMove(e) {\n            if (!touchItem) return;\n            const touch = e.touches[0];\n            touchItem.style.left = (touch.clientX - touchOffset.x) + 'px';\n            touchItem.style.top = (touch.clientY - touchOffset.y) + 'px';\n            \n            // Check drop zones\n            const touchElement = document.elementFromPoint(touch.clientX, touch.clientY);\n            if (touchElement && (touchElement.id === 'drop-zone-a' || touchElement.id === 'drop-zone-b')) {\n                [dropZoneA, dropZoneB].forEach(zone => zone.classList.remove('drag-over'));\n                touchElement.classList.add('drag-over');\n            } else {\n                [dropZoneA, dropZoneB].forEach(zone => zone.classList.remove('drag-over'));\n            }\n            \n            e.preventDefault();\n        }\n        \n        function handleTouchEnd(e) {\n            if (!touchItem) return;\n            \n            const touch = e.changedTouches[0];\n            const touchElement = document.elementFromPoint(touch.clientX, touch.clientY);\n            \n            if (touchElement && (touchElement.id === 'drop-zone-a' || touchElement.id === 'drop-zoneb')) {\n                const category = touchElement.dataset.category;\n                processDrop(category);\n            }\n            \n            // Reset item position\n            touchItem.style.position = '';\n            touchItem.style.zIndex = '';\n            touchItem.style.left = '';\n            touchItem.style.top = '';\n            touchItem.style.transition = '';\n            touchItem = null;\n            \n            [dropZoneA, dropZoneB].forEach(zone => zone.classList.remove('drag-over'));\n            e.preventDefault();\n        }\n        \n        function processDrop(category) {\n            const round = data.rondas[currentRound];\n            const isCorrect = category === round.respuesta;\n            \n            if (isCorrect) {\n                score++;\n                feedback.textContent = round.feedback_correcto;\n                feedback.className = 'feedback correct';\n            } else {\n                feedback.textContent = round.feedback_incorrecto;\n                feedback.className = 'feedback incorrect';\n            }\n            \n            scoreDisplay.textContent = score;\n            feedback.classList.add('show');\n            \n            // Disable dragging\n            draggableItem.draggable = false;\n            draggableItem.style.cursor = 'default';\n            \n            // Show next button or completion\n            if (currentRound < data.rondas.length - 1) {\n                nextBtn.classList.add('show');\n            } else {\n                setTimeout(showCompletion, 1000);\n            }\n        }\n        \n        function nextRound() {\n            currentRound++;\n            updateRound();\n            nextBtn.classList.remove('show');\n            feedback.classList.remove('show');\n        }\n        \n        function updateRound() {\n            const round = data.rondas[currentRound];\n            document.getElementById('round-number').textContent = round.ronda;\n            document.getElementById('item-text').textContent = round.item;\n            document.getElementById('item-contexto').textContent = round.contexto;\n            \n            // Reset dragging\n            draggableItem.draggable = true;\n            draggableItem.style.cursor = 'move';\n            draggableItem.classList.remove('dragging');\n            \n            // Reset drop zones\n            [dropZoneA, dropZoneB].forEach(zone => zone.classList.remove('drag-over'));\n        }\n        \n        function showCompletion() {\n            gameContainer.style.display = 'none';\n            document.getElementById('final-score').textContent = score;\n            completionMessage.classList.add('show');\n            \n            // SCORM completion\n            _scormComplete(score);\n        }\n        \n        function resetGame() {\n            currentRound = 0;\n            score = 0;\n            scoreDisplay.textContent = score;\n            \n            gameContainer.style.display = 'block';\n            completionMessage.classList.remove('show');\n            \n            updateRound();\n            nextBtn.classList.remove('show');\n            feedback.classList.remove('show');\n            \n            // SCORM re-initialization\n            _scormInit();\n        }\n        \n        // SCORM functions\n        function _scormInit() {\n            if (window.API) {\n                window.API.LMSInitialize(\"\");\n            }\n        }\n        \n        function _scormComplete(s) {\n            if (window.API) {\n                if (s != null) {\n                    window.API.LMSSetValue(\"cmi.core.score.raw\", s);\n                }\n                window.API.LMSSetValue(\"cmi.core.lesson_status\", \"completed\");\n                window.API.LMSCommit(\"\");\n                window.API.LMSFinish(\"\");\n            }\n        }\n        \n        // Initialize game\n        _scormInit();\n    </script>\n</body>\n</html>"}