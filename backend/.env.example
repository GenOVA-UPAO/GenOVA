# --- Core infrastructure ---
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@[AWS-REGION].pooler.supabase.com:5432/postgres?sslmode=require
# Set to "production" to enforce CORS_ORIGINS and enable prod-only validations.
# Default is "dev" (permissive CORS — do NOT leave unset in production).
ENV=production
# Port the server listens on. Railway injects this automatically.
PORT=8000
LOG_LEVEL=INFO

# --- Auth ---
# JWT_SECRET MUST be >=16 chars. The backend hard-fails on startup with weak
# defaults ("change-me", "secret", ""). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
# Set to 0 once all clients use httpOnly cookie auth (drops legacy Bearer header support).
AUTH_ACCEPT_BEARER=0

# --- CORS ---
# Comma-separated list of extra allowed frontend origins in production.
CORS_ORIGINS=https://gen-ova-frontend.vercel.app
# Cookie SameSite policy. Use "none" (+ Secure=True auto-enabled) when frontend
# and backend are on different domains (e.g. Vercel + Railway). Use "strict" when
# same domain. Default: "lax" (blocks cross-site cookie delivery).
COOKIE_SAMESITE=none

# --- Database pool ---
# Supabase Transaction pooler connection pool tuning.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- LLM provider credentials ---
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
# OpenCode Go — personal subscription for DeepSeek V4 Pro access.
OPENCODE_API_KEY=oc_your_opencode_key_here
GEMINI_API_KEY=
# Optional Hugging Face Inference API token for FLUX.1-schnell image generation.
HF_TOKEN=
# Hugging Face model identifier (defaults to black-forest-labs/FLUX.1-schnell)
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Alternative image providers (user/admin can configure these per-account).
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=stabilityai/stable-diffusion-3-5-large
RUNWARE_API_KEY=
RUNWARE_IMAGE_MODEL=runware:100@1
FALAI_API_KEY=
FALAI_IMAGE_MODEL=fal-ai/flux/schnell
# Sent as HTTP-Referer to OpenRouter for app attribution.
APP_URL=https://genova.ai

# --- LLM config ---
# Comma-separated subset of catalog IDs (see backend/ova/llm_helpers.py):
#   groq-llama-3.3-70b, groq-gpt-oss-120b, groq-qwen3-32b, openrouter-qwen3-coder
# Empty = surface all engines.
OVA_ENABLED_LLMS=
# Per-call LLM timeout in seconds (default: 120). Tune down on time-boxed workers.
LLM_TIMEOUT_S=120

# --- OVA generation ---
# Time the (simulated) generation job takes from start to finish.
OVA_GENERATION_DURATION_SECONDS=14
# Local-disk fallback for SCORM zips when Supabase Storage is not configured.
# Defaults to backend/scorm_output/. Primary persistence is Supabase Storage.
OVA_OUTPUT_DIR=
# Max images generated per ENGAGE resource (via Hugging Face if HF_TOKEN set).
OVA_MAX_GENERATED_IMAGES=2

# --- Uploads ---
UPLOAD_MAX_FILES=5
UPLOAD_MAX_FILE_SIZE_MB=20

# --- Supabase Storage (SCORM zip persistence) ---
# Without these, the backend falls back to local-disk SCORM persistence (dev mode).
# SERVICE_ROLE_KEY is a server-only secret. NEVER expose to the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=scorm-packages

# --- RAG (pgvector + embeddings) ---
# `gemini`     = Google `gemini-embedding-2-preview` (Public Preview, Mar 2026).
#                Natively multimodal: ingests text, images (PNG/JPEG), PDFs (6
#                pages/req with OCR), audio (no Whisper needed) and video
#                (up to 120 s). Matryoshka-truncated to 768-d. Default.
# `gemini-001` = Stable fallback `gemini-embedding-001` (text-only, GA).
#                Use when the Preview model is unstable.
# `local`      = sentence-transformers MiniLM (384-d, only if RAM allows).
RAG_EMBEDDER=gemini
# Override chunker behavior (defaults: 800 chars, 150 overlap, 100 chunks max).
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_MAX_CHUNKS_PER_FILE=100
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=6000
# Set RAG_DISABLED=1 to skip the parse/chunk/embed pipeline entirely.
RAG_DISABLED=

# --- SMTP (Gmail Recovery Service) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=soporte.genova.upao@gmail.com
SMTP_PASSWORD=replace-with-google-app-password
