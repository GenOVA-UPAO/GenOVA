MIN_PROMPT_CHARS=10
OVA_ENABLED_LLMS=openai,gemini,claude
OVA_GENERATION_DURATION_SECONDS=14
OVA_GENERATION_JOB_TTL_SECONDS=300
# Note: in-memory jobs are process-local; in production prefer shared storage (e.g., Redis/DB). Single worker is only a temporary workaround.
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@[AWS-REGION].pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# LLM Providers — Metodología 5E
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Production CORS — comma-separated list of allowed frontend origins
# Example: https://genova.vercel.app,https://genova.example.com
CORS_ORIGINS=
