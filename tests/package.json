{
  "name": "genova-tests",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test:unit": "cucumber-js --config cucumber.unit.config.mjs",
    "test:e2e": "bddgen --config playwright.config.js && playwright test --config playwright.config.js",
    "test:e2e:ui": "bddgen --config playwright.config.js && playwright test --config playwright.config.js --ui"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.50.0",
    "happy-dom": "^20.10.3",
    "playwright-bdd": "^9.1.0"
  }
}
